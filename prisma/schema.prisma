generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Theory {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  author    String
  tag       String
  upvotes   Int      @default(0)
  clicks    Int      @default(0)
  createdAt DateTime @default(now())

  comments  Comment[]
}

model Comment {
  id        String   @id @default(uuid())
  theoryId  String
  author    String
  text      String   @db.Text
  upvotes   Int      @default(0)
  clicks    Int      @default(0)
  createdAt DateTime @default(now())

  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")

  theory    Theory   @relation(fields: [theoryId], references: [id], onDelete: Cascade)
}

model Character {
  id      String @id
  likes   Int    @default(0)
}

model GlobalStat {
  id    String @id @default("counter")
  count Int    @default(12438201)
}

model CelebrityVideo {
  id        String   @id @default(uuid())
  title     String
  src       String
  poster    String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model DynamicImage {
  id        String   @id @default(uuid())
  category  String
  src       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model DebateRegistration {
  id             String   @id @default(uuid())
  fullName       String
  age            Int
  contactNumber  String
  email          String
  likedFilm      String
  likedReason    String   @db.Text
  dislikedReason String   @db.Text
  inHyderabad    String
  discussPart    String   @db.Text
  okayFilmed     String
  socialHandles  String
  createdAt      DateTime @default(now())
}

model DebateSetting {
  id        String    @id @default("settings")
  isActive  Boolean   @default(true)
  closingAt DateTime?
}
